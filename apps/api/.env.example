# kodanAPPS API - Environment Variables
# Copiar a .env y completar valores

# Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=admkoda_BBDD_APPS
DB_USER=kodan_apps
DB_PASS=your_secure_password_here

# JWT
JWT_SECRET=generate-with-openssl-rand-base64-32

# Entorno
APP_ENV=development

# Sistema
SYSTEM_TENANT_ID=1

# URLs Frontend (para CORS)
FRONTEND_CRM_URL=https://crm.kodan.software
FRONTEND_TRACKER_URL=https://tracker.kodan.software
FRONTEND_SUPERADMIN_URL=https://superadmin.kodan.software