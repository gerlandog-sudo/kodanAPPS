{
  "name": "kodan/api",
  "description": "API unificada para la plataforma kodanAPPS",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "pestphp/pest": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "kodanAPPS\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "phpstan": "phpstan analyse",
    "phpstan:baseline": "phpstan analyse --generate-baseline"
  }
}
